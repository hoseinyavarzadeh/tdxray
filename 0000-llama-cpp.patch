+////
+//// NOTE:
+//// Use '-DBUILD_SHARED_LIBS=OFF' when setting up your project with cmake. Otherwise, this library will not be easily portable
+////
+
+#include "common.h"
+#include "llama.h"
+
+#include <cstdio>
+#include <cstring>
+#include <fstream>
+#include <string>
+#include <vector>
+
+#include "libtokenize.h"
+
+static llama_context *ctx = nullptr;
+static llama_model* model = nullptr;
+static const llama_vocab * vocab = nullptr;
+
+extern "C" void libtokenize_free_string(const char* str) {
+    delete [] str;
+}
+
+extern "C" void libtokenize_free_tokens(unsigned long* tokens) {
+    delete [] tokens;
+}
+
+extern "C" unsigned long libtokenize_get_tokens(const char* prompt_ptr, unsigned long** tokens_out) {
+    if (ctx == nullptr || model == nullptr)
+        return -1;
+
+    auto prompt = std::string(prompt_ptr);
+
+    const bool model_wants_add_bos = llama_vocab_get_add_bos(vocab);
+    const bool add_bos = model_wants_add_bos;
+    const bool parse_special = true;
+    const bool escape = true;
+
+    if (escape)
+        string_process_escapes(prompt);
+
+    auto tokens = common_tokenize(vocab, prompt, add_bos, parse_special);
+    *tokens_out = new unsigned long[tokens.size()];
+    auto dest = *tokens_out;
+
+    auto i = 0u;
+    for (const auto token: tokens)
+        dest[i++] = token;
+
+    return tokens.size();
+}
+
+extern "C" const char* libtokenize_tokens_to_string(const unsigned long* tokens, unsigned long num_tokens) {
+    std::vector<llama_token> token_vec(tokens, tokens + num_tokens);
+    auto msg = common_detokenize(ctx, token_vec);
+    auto* ret = new char[msg.size() + 1];
+
+    memcpy(ret, msg.c_str(), msg.size());
+    ret[msg.size()] = '\0';
+
+    return ret;
+}
+
+extern "C" int libtokenize_init(const char* model_path) {
+    llama_backend_init();
+
+    llama_model_params model_params = llama_model_default_params();
+    model_params.vocab_only = true;
+    model = llama_model_load_from_file(model_path, model_params);
+    if (!model) {
+        fprintf(stderr, "Error: could not load model from file '%s'.\n", model_path);
+        return -1;
+    }
+
+    vocab = llama_model_get_vocab(model);
+
+    llama_context_params ctx_params = llama_context_default_params();
+    ctx = llama_init_from_model(model, ctx_params);
+    if (!ctx) {
+        fprintf(stderr, "Error: could not create context.\n");
+        return -1;
+    }
+
+    return 0;
+}
+
+extern "C" void libtokenize_exit(void) {
+    if (ctx)
+        llama_free(ctx);
+    if (model)
+        llama_model_free(model);
+
+    ctx = nullptr;
+    model = nullptr;
+}
